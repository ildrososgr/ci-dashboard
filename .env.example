# Required
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional (defaults shown)
CLICKUP_SPACE_ID=90154275110
CLICKUP_TEAM_ID=90151097204

# How often to refresh (hours). 0 = run once and exit.
REFRESH_INTERVAL_HOURS=4

# Where to write the dashboard HTML
OUTPUT_DIR=output

# Optional: comma-separated list of team members to include (first and/or last names accepted)
# If empty, all projects are considered. Example:
# TEAM_MEMBERS=Nikos Papachristos, Ilias Drosos, Kyriakos Tzanetolakos
TEAM_MEMBERS=
